<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SmokingTracker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.SmokingTracker</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.App.Starting.Light" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">#FFFFFBFE</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.App.Starting.Dark" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">#1C1B1F</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>